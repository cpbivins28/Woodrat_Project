# 2. Rename MiSeq fastq.gz files
## The trimmomatic script will not work if there are any underscore symbols anywhere other than where the file names delimit R1 vs R2 files. There are underscores separating every part of the sample IDs, so these need to be changed to dashes. 

import os

def rename_files():
    # Get all files in current directory
    files = os.listdir('.')
    
    for old_name in files:
        # Skip if it's not a fastq.gz file
        if not old_name.endswith('.fastq.gz') and old_name != 'laneBarcode.html':
            continue
            
        # Split the filename at _R1_ or _R2_
        new_name = old_name
        if '_R1_' in new_name:
            parts = new_name.split('_R1_')
            # Replace underscores with dashes in the first part
            parts[0] = parts[0].replace('_', '-')
            # Join back with _R1_
            new_name = '_R1_'.join(parts)
        elif '_R2_' in new_name:
            parts = new_name.split('_R2_')
            # Replace underscores with dashes in the first part
            parts[0] = parts[0].replace('_', '-')
            # Join back with _R2_
            new_name = '_R2_'.join(parts)
        else:
            # If no R1 or R2, just replace all underscores
            new_name = new_name.replace('_', '-')
        
        # Rename the file if the name has changed
        if new_name != old_name:
            try:
                os.rename(old_name, new_name)
                print(f'Renamed: {old_name} -> {new_name}')
            except OSError as e:
                print(f'Error renaming {old_name}: {e}')

if __name__ == '__main__':
    # Ask for confirmation before proceeding
    print("This script will rename files in the current directory.")
    response = input("Do you want to proceed? (y/n): ")
    if response.lower() == 'y':
        rename_files()
    else:
        print("Operation cancelled.")

