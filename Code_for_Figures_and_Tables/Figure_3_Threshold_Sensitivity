#!/usr/bin/env python3
# ============================================================
# Woodrat Project — Figure 5 (All Panels A–D, Exported Separately)
# ============================================================
# Panels:
#   A. OTU richness vs. threshold
#   B. Sample detections vs. threshold
#
# Each saved as a separate high-res SVG
# ============================================================

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from pathlib import Path
import numpy as np

# ------------------------------------------------------------
# File paths
# ------------------------------------------------------------
base_dir = Path("/Users/cbivins/Desktop/Woodrat_Project_NEATEST/Figure_5")
input_path = base_dir / "threshold_summary_global.csv"

# ------------------------------------------------------------
# Load and prepare data
# ------------------------------------------------------------
df = pd.read_csv(input_path)
df["guild"] = pd.Categorical(df["guild"], categories=["Truffle", "Epigeous_ECM"], ordered=True)
df["mean_samples_per_OTU"] = df["n_samples_detected"] / df["n_OTUs_detected"]

# ------------------------------------------------------------
# Styling
# ------------------------------------------------------------
sns.set(style="white", context="talk")
palette = sns.color_palette("Set2", 2)
x_ticks = np.array([0.0, 0.2, 0.5, 1.0, 1.5])

def clean_axis(ax, xlabel, ylabel, title):
    ax.set_xlabel(xlabel)
    ax.set_ylabel(ylabel)
    ax.set_title(title)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.grid(False)
    return ax

# ============================================================
# PANEL A — Richness
# ============================================================
fig, ax = plt.subplots(figsize=(6, 5))
sns.lineplot(
    data=df,
    x="threshold",
    y="n_OTUs_detected",
    hue="guild",
    marker="o",
    linewidth=2.2,
    palette=palette,
    ax=ax
)
ax.set_xticks(x_ticks)
clean_axis(ax, "Relative abundance threshold (%)", "Number of OTUs detected", "A. OTU richness vs threshold")
ax.legend(title="Guild", loc="upper right", frameon=False)
plt.tight_layout()
fig.savefig(base_dir / "Figure_5A_OTU_richness.svg", dpi=300)
plt.close(fig)

# ============================================================
# PANEL B — Detection frequency
# ============================================================
fig, ax = plt.subplots(figsize=(6, 5))
sns.lineplot(
    data=df,
    x="threshold",
    y="n_samples_detected",
    hue="guild",
    marker="o",
    linewidth=2.2,
    palette=palette,
    ax=ax
)
ax.set_xticks(x_ticks)
clean_axis(ax, "Relative abundance threshold (%)", "Number of samples with detections", "B. Sample detections vs threshold")
ax.legend(title="Guild", loc="upper right", frameon=False)
plt.tight_layout()
fig.savefig(base_dir / "Figure_5B_Sample_detections.svg", dpi=300)
plt.close(fig)

# ------------------------------------------------------------
# Summary message
# ------------------------------------------------------------
print("\n✅ All panels exported successfully:")
print(" - Figure_5A_OTU_richness.svg")
print(" - Figure_5B_Sample_detections.svg")
print(f"\nFiles saved in:\n{base_dir}\n")







