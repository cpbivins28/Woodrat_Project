# Define output directory.
out_dir  <- "/Users/cbivins/Desktop/Woodrat_Project_NEATEST/mckenzie_h2_h4_temporal"

# Create output directory if it does not already exist.
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)

# --------------------------------------------------------------------------
# Parameters
# --------------------------------------------------------------------------

# Define the relative-abundance thresholds to evaluate.
thresholds <- c(0.0, 0.2, 0.5, 1.0, 1.5)

# Define the focal site.
keep_site   <- "Mckenzie"

# Define the focal year.
keep_year   <- 2

# Define the focal nests.
keep_nests  <- c("M1", "M3", "M6", "M8", "M9", "M10")

# Define the focal months and their intended order.
