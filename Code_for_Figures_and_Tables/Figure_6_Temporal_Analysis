# --------------------------------------------------
# Helper function: threshold label for filenames
# --------------------------------------------------
threshold_label <- function(x) {
  if (x == 0) return("0pct")
  out <- gsub("\\.", "p", as.character(x))
  paste0(out, "pct")
}

# --------------------------------------------------
# Helper function: safely collect model warnings
# --------------------------------------------------
fit_with_warnings <- function(expr) {
  warning_messages <- character(0)

  fit <- withCallingHandlers(
    tryCatch(
      expr,
      error = function(e) e
    ),
    warning = function(w) {
      warning_messages <<- c(warning_messages, conditionMessage(w))
      invokeRestart("muffleWarning")
    }
  )

  list(
    fit = fit,
    warnings = unique(warning_messages)
  )
}

# --------------------------------------------------
# Helper function: detect problematic mixed model fit
# --------------------------------------------------
mixed_model_problem <- function(model, warnings_vec = character(0)) {

  if (inherits(model, "error")) {
    return(TRUE)
  }

  if (!inherits(model, "merMod")) {
    return(TRUE)
  }

  # Check singularity for mixed models.
  singular_flag <- FALSE
  singular_flag <- tryCatch(
    lme4::isSingular(model, tol = 1e-4),
    error = function(e) FALSE
  )

  # Check optimizer / convergence messages.
  conv_messages <- character(0)
  conv_messages <- tryCatch(
    unlist(model@optinfo$conv$lme4$messages),
    error = function(e) character(0)
  )

  # Flag warnings that indicate major fit issues.
  bad_warning_patterns <- c(
    "failed to converge",
    "degenerate",
    "singular",
    "non-positive-definite",
    "unable to evaluate scaled gradient",
    "Model failed to converge",
    "boundary \\(singular\\) fit"
  )

  has_bad_warning <- FALSE
  if (length(warnings_vec) > 0 || length(conv_messages) > 0) {
    all_msgs <- c(warnings_vec, conv_messages)
    has_bad_warning <- any(
      grepl(
        paste(bad_warning_patterns, collapse = "|"),
        all_msgs,
        ignore.case = TRUE
      )
    )
  }

  return(isTRUE(singular_flag) || has_bad_warning)
}

# --------------------------------------------------
# Helper function: compute overdispersion ratio
# --------------------------------------------------
overdispersion_ratio <- function(model) {

  # Handle standard GLM objects.
  if (inherits(model, "glm")) {
    rp <- residuals(model, type = "pearson")
    rdf <- df.residual(model)

    if (rdf <= 0) return(NA_real_)
    return(sum(rp^2, na.rm = TRUE) / rdf)
  }

  # Handle mixed models approximately.
  if (inherits(model, "merMod")) {
    rp <- residuals(model, type = "pearson")
    n_obs <- nobs(model)

    # Approximate residual df as n - number of fixed effects - 1.
    # This is imperfect, but is acceptable here as a pragmatic screening rule.
    n_fixef <- tryCatch(length(lme4::fixef(model)), error = function(e) NA_integer_)
    rdf <- n_obs - n_fixef - 1

    if (is.na(rdf) || rdf <= 0) return(NA_real_)
    return(sum(rp^2, na.rm = TRUE) / rdf)
  }

  return(NA_real_)
}

# --------------------------------------------------
# Helper function: extract LRT table from anova(model0, model1)
# --------------------------------------------------
extract_lrt_table <- function(lrt_obj, tested_term) {

  tab <- as.data.frame(lrt_obj)
  tab <- tibble::rownames_to_column(tab, "Model_Row")

  # Keep only the second row, which corresponds to the fuller model.
  if (nrow(tab) < 2) {
    stop("LRT table did not contain two rows.")
  }

  tab2 <- tab[2, , drop = FALSE]

  # Identify p-value column robustly.
  p_col <- grep("^Pr\\(", names(tab2), value = TRUE)
  if (length(p_col) != 1) {
    stop("Could not uniquely identify p-value column in LRT table.")
  }

  # Identify the test statistic column robustly.
  stat_col <- NULL

  if ("Chisq" %in% names(tab2)) {
    stat_col <- "Chisq"
  } else if ("Deviance" %in% names(tab2)) {
    stat_col <- "Deviance"
  } else if ("LR stat." %in% names(tab2)) {
    stat_col <- "LR stat."
  } else {
    chisq_like <- grep("Chisq|Deviance|LR", names(tab2), value = TRUE)
    chisq_like <- chisq_like[!grepl("^Pr\\(", chisq_like)]
    if (length(chisq_like) >= 1) {
      stat_col <- chisq_like[1]
    }
  }

  if (is.null(stat_col)) {
    stop(
      paste0(
        "Could not identify test statistic column in LRT table. Columns were: ",
        paste(names(tab2), collapse = ", ")
      )
    )
  }

  if (!("Df" %in% names(tab2))) {
    stop("Could not identify Df column in LRT table.")
  }

  out <- dplyr::transmute(
    tab2,
    Term = tested_term,
    Df = Df,
    Chisq = .data[[stat_col]],
    p_value = .data[[p_col]]
  )

  return(out)
}

# --------------------------------------------------
# Helper function: tidy coefficients safely
# --------------------------------------------------
tidy_coefficients <- function(model) {

  if (inherits(model, "merMod")) {
    return(broom.mixed::tidy(model, effects = "fixed"))
  }

  return(broom::tidy(model))
}

# --------------------------------------------------
# Helper function: fit detection model with mixed first, fixed fallback
# --------------------------------------------------
fit_detection_model <- function(dat) {

  # Full mixed model with Month effect.
  full_mixed_fit <- fit_with_warnings(
    lme4::glmer(
      AnyDetected ~ Month + (1 | Nest_ID),
      family = stats::binomial,
      data = dat,
      control = lme4::glmerControl(
        optimizer = "bobyqa",
        optCtrl = list(maxfun = 2e5)
      )
    )
  )

  # Reduced mixed model without Month.
  red_mixed_fit <- fit_with_warnings(
    lme4::glmer(
      AnyDetected ~ (1 | Nest_ID),
      family = stats::binomial,
      data = dat,
      control = lme4::glmerControl(
        optimizer = "bobyqa",
        optCtrl = list(maxfun = 2e5)
      )
    )
  )

  mixed_ok <- TRUE
  mixed_ok <- mixed_ok && !inherits(full_mixed_fit$fit, "error")
  mixed_ok <- mixed_ok && !inherits(red_mixed_fit$fit, "error")
  mixed_ok <- mixed_ok && !mixed_model_problem(full_mixed_fit$fit, full_mixed_fit$warnings)
  mixed_ok <- mixed_ok && !mixed_model_problem(red_mixed_fit$fit, red_mixed_fit$warnings)

  if (isTRUE(mixed_ok)) {
    full_model <- full_mixed_fit$fit
    reduced_model <- red_mixed_fit$fit

    lrt <- stats::anova(reduced_model, full_model, test = "Chisq")
    lrt <- extract_lrt_table(lrt, tested_term = "Month")

    return(list(
      full_model = full_model,
      reduced_model = reduced_model,
      lrt_table = lrt,
      model_type = "mixed_random_intercept",
      family = "binomial",
      warnings = unique(c(full_mixed_fit$warnings, red_mixed_fit$warnings))
    ))
  }

  # Fixed-effect fallback.
  full_fixed <- stats::glm(
    AnyDetected ~ Month + Nest_ID,
    family = stats::binomial,
    data = dat
  )

  reduced_fixed <- stats::glm(
    AnyDetected ~ Nest_ID,
    family = stats::binomial,
    data = dat
  )

  lrt <- stats::anova(reduced_fixed, full_fixed, test = "Chisq")
  lrt <- extract_lrt_table(lrt, tested_term = "Month")

  return(list(
    full_model = full_fixed,
    reduced_model = reduced_fixed,
    lrt_table = lrt,
    model_type = "fixed_effect_nest",
    family = "binomial",
    warnings = unique(c(full_mixed_fit$warnings, red_mixed_fit$warnings))
  ))
}

# --------------------------------------------------
# Helper function: fit richness model with mixed first, fixed fallback
# --------------------------------------------------
fit_richness_model <- function(dat) {

  # ------------------------------
  # Try mixed-model Poisson first
  # ------------------------------
  full_pois_mixed_fit <- fit_with_warnings(
    lme4::glmer(
      OTU_Richness ~ Month + (1 | Nest_ID),
      family = stats::poisson,
      data = dat,
      control = lme4::glmerControl(
        optimizer = "bobyqa",
        optCtrl = list(maxfun = 2e5)
      )
    )
  )

  red_pois_mixed_fit <- fit_with_warnings(
    lme4::glmer(
      OTU_Richness ~ (1 | Nest_ID),
      family = stats::poisson,
      data = dat,
      control = lme4::glmerControl(
        optimizer = "bobyqa",
        optCtrl = list(maxfun = 2e5)
      )
    )
  )

  pois_mixed_ok <- TRUE
  pois_mixed_ok <- pois_mixed_ok && !inherits(full_pois_mixed_fit$fit, "error")
  pois_mixed_ok <- pois_mixed_ok && !inherits(red_pois_mixed_fit$fit, "error")
  pois_mixed_ok <- pois_mixed_ok && !mixed_model_problem(full_pois_mixed_fit$fit, full_pois_mixed_fit$warnings)
  pois_mixed_ok <- pois_mixed_ok && !mixed_model_problem(red_pois_mixed_fit$fit, red_pois_mixed_fit$warnings)

  if (isTRUE(pois_mixed_ok)) {

    full_model <- full_pois_mixed_fit$fit
    reduced_model <- red_pois_mixed_fit$fit

    disp <- overdispersion_ratio(full_model)

    # If overdispersion is modest, keep Poisson mixed model.
    if (is.na(disp) || disp <= 1.5) {
      lrt <- stats::anova(reduced_model, full_model, test = "Chisq")
      lrt <- extract_lrt_table(lrt, tested_term = "Month")

      return(list(
        full_model = full_model,
        reduced_model = reduced_model,
        lrt_table = lrt,
        model_type = "mixed_random_intercept",
        family = "poisson",
        poisson_overdispersion_ratio = disp,
        warnings = unique(c(full_pois_mixed_fit$warnings, red_pois_mixed_fit$warnings))
      ))
    }

    # If overdispersed, try negative binomial mixed model.
    full_nb_mixed_fit <- fit_with_warnings(
      lme4::glmer.nb(
        OTU_Richness ~ Month + (1 | Nest_ID),
        data = dat,
        control = lme4::glmerControl(
          optimizer = "bobyqa",
          optCtrl = list(maxfun = 2e5)
        )
      )
    )

    red_nb_mixed_fit <- fit_with_warnings(
      lme4::glmer.nb(
        OTU_Richness ~ (1 | Nest_ID),
        data = dat,
        control = lme4::glmerControl(
          optimizer = "bobyqa",
          optCtrl = list(maxfun = 2e5)
        )
      )
    )

    nb_mixed_ok <- TRUE
    nb_mixed_ok <- nb_mixed_ok && !inherits(full_nb_mixed_fit$fit, "error")
    nb_mixed_ok <- nb_mixed_ok && !inherits(red_nb_mixed_fit$fit, "error")
    nb_mixed_ok <- nb_mixed_ok && !mixed_model_problem(full_nb_mixed_fit$fit, full_nb_mixed_fit$warnings)
    nb_mixed_ok <- nb_mixed_ok && !mixed_model_problem(red_nb_mixed_fit$fit, red_nb_mixed_fit$warnings)

    if (isTRUE(nb_mixed_ok)) {
      full_model <- full_nb_mixed_fit$fit
      reduced_model <- red_nb_mixed_fit$fit

      lrt <- stats::anova(reduced_model, full_model, test = "Chisq")
      lrt <- extract_lrt_table(lrt, tested_term = "Month")

      return(list(
        full_model = full_model,
        reduced_model = reduced_model,
        lrt_table = lrt,
        model_type = "mixed_random_intercept",
        family = "negative_binomial",
        poisson_overdispersion_ratio = disp,
        warnings = unique(c(
          full_pois_mixed_fit$warnings,
          red_pois_mixed_fit$warnings,
          full_nb_mixed_fit$warnings,
          red_nb_mixed_fit$warnings
        ))
      ))
    }
  }

  # ------------------------------
  # Fixed-effect fallback route
  # ------------------------------
  full_pois_fixed <- stats::glm(
    OTU_Richness ~ Month + Nest_ID,
    family = stats::poisson,
    data = dat
  )

  disp_fixed <- overdispersion_ratio(full_pois_fixed)

  if (!is.na(disp_fixed) && disp_fixed > 1.5) {

    full_nb_fixed <- MASS::glm.nb(
      OTU_Richness ~ Month + Nest_ID,
      data = dat
    )

    red_nb_fixed <- MASS::glm.nb(
      OTU_Richness ~ Nest_ID,
      data = dat
    )

    lrt <- stats::anova(red_nb_fixed, full_nb_fixed, test = "Chisq")
    lrt <- extract_lrt_table(lrt, tested_term = "Month")

    return(list(
      full_model = full_nb_fixed,
      reduced_model = red_nb_fixed,
      lrt_table = lrt,
      model_type = "fixed_effect_nest",
      family = "negative_binomial",
      poisson_overdispersion_ratio = disp_fixed,
      warnings = character(0)
    ))
  }

  red_pois_fixed <- stats::glm(
    OTU_Richness ~ Nest_ID,
    family = stats::poisson,
    data = dat
  )

  lrt <- stats::anova(red_pois_fixed, full_pois_fixed, test = "Chisq")
  lrt <- extract_lrt_table(lrt, tested_term = "Month")

  return(list(
    full_model = full_pois_fixed,
    reduced_model = red_pois_fixed,
    lrt_table = lrt,
    model_type = "fixed_effect_nest",
    family = "poisson",
    poisson_overdispersion_ratio = disp_fixed,
    warnings = character(0)
  ))
}

# --------------------------------------------------
# Load data
# --------------------------------------------------
otu   <- readr::read_csv(otu_fp, show_col_types = FALSE)
guild <- readr::read_csv(guild_fp, show_col_types = FALSE)
meta  <- readr::read_csv(meta_fp, show_col_types = FALSE)

# --------------------------------------------------
# Basic checks
# --------------------------------------------------
stopifnot("OTU_ID" %in% names(otu))
stopifnot(all(c("OTU_ID", "primary_lifestyle", "Fruitbody_type_template") %in% names(guild)))
stopifnot(all(c("Sample_ID", "Site", "Nest_ID", "Year", "Month") %in% names(meta)))

# --------------------------------------------------
# Restrict metadata to McKenzie year 2, focal nests, focal months
# --------------------------------------------------
meta_mck <- dplyr::filter(
  meta,
  Site == keep_site,
  Year == keep_year,
  Nest_ID %in% keep_nests,
  Month %in% keep_months
)

meta_mck <- dplyr::select(meta_mck, Sample_ID, Nest_ID, Month)
meta_mck <- dplyr::distinct(meta_mck)

if (nrow(meta_mck) == 0) {
  stop("No rows after filtering to Mckenzie year 2 + keep_nests + keep_months.")
}

meta_mck <- dplyr::mutate(
  meta_mck,
  Nest_ID = factor(Nest_ID, levels = keep_nests),
  Month = factor(Month, levels = keep_months, ordered = TRUE)
)

mck_samples <- unique(meta_mck$Sample_ID)

# --------------------------------------------------
# Define guild membership EXACTLY
# --------------------------------------------------
truffle_tbl <- dplyr::filter(
  guild,
  primary_lifestyle == "ectomycorrhizal",
  Fruitbody_type_template == "gasteroid-hypogeous"
)

truffle_ids <- unique(truffle_tbl$OTU_ID)

epigeous_tbl <- dplyr::filter(
  guild,
  primary_lifestyle == "ectomycorrhizal",
  Fruitbody_type_template %in% c(
    "agaricoid",
    "gasteroid",
    "clavarioid",
    "apothecium_(hymenium_on_surface)"
  )
)

epigeous_ids <- unique(epigeous_tbl$OTU_ID)

# --------------------------------------------------
# Build taxonomy table for OTU-level outputs
# --------------------------------------------------
truffle_tax <- dplyr::filter(guild, OTU_ID %in% truffle_ids)
truffle_tax <- dplyr::select(
  truffle_tax,
  OTU_ID, Kingdom, Phylum, Class, Order, Family, Genus, Species,
  primary_lifestyle, Fruitbody_type_template
)
truffle_tax <- dplyr::mutate(truffle_tax, Guild = "Truffle")

epigeous_tax <- dplyr::filter(guild, OTU_ID %in% epigeous_ids)
epigeous_tax <- dplyr::select(
  epigeous_tax,
  OTU_ID, Kingdom, Phylum, Class, Order, Family, Genus, Species,
  primary_lifestyle, Fruitbody_type_template
)
epigeous_tax <- dplyr::mutate(epigeous_tax, Guild = "Epigeous_ECM")

guild_tax <- dplyr::bind_rows(truffle_tax, epigeous_tax)
guild_tax <- dplyr::distinct(guild_tax)

# --------------------------------------------------
# Match OTU sample columns to metadata sample IDs
# --------------------------------------------------
otu_samples <- setdiff(colnames(otu), "OTU_ID")
mck_samples_present <- intersect(otu_samples, mck_samples)

if (length(mck_samples_present) == 0) {
  stop("No McKenzie year 2 Sample_IDs found in OTU table columns.")
}

# --------------------------------------------------
# Build long OTU table for retained McKenzie samples only
# --------------------------------------------------
otu_sub <- dplyr::select(otu, OTU_ID, dplyr::all_of(mck_samples_present))

otu_long <- tidyr::pivot_longer(
  otu_sub,
  cols = -OTU_ID,
  names_to = "Sample_ID",
  values_to = "RA"
)

otu_long$RA[is.na(otu_long$RA)] <- 0

otu_long <- dplyr::left_join(otu_long, meta_mck, by = "Sample_ID")

otu_long <- dplyr::mutate(
  otu_long,
  Guild = dplyr::case_when(
    OTU_ID %in% truffle_ids ~ "Truffle",
    OTU_ID %in% epigeous_ids ~ "Epigeous_ECM",
    TRUE ~ NA_character_
  )
)

otu_long <- dplyr::filter(otu_long, !is.na(Guild))

otu_long <- dplyr::mutate(
  otu_long,
  Nest_ID = factor(Nest_ID, levels = keep_nests),
  Month = factor(Month, levels = keep_months, ordered = TRUE),
  Guild = factor(Guild, levels = c("Truffle", "Epigeous_ECM"))
)

# --------------------------------------------------
# Sample-level summaries across thresholds
# --------------------------------------------------
sample_level_list <- list()

for (i in seq_along(thresholds)) {

  th <- thresholds[i]
  tmp <- otu_long

  if (th == 0) {
    tmp <- dplyr::mutate(tmp, Detected = RA > 0)
  } else {
    tmp <- dplyr::mutate(tmp, Detected = RA >= th)
  }

  tmp <- dplyr::group_by(tmp, Sample_ID, Nest_ID, Month, Guild)

  tmp <- dplyr::summarise(
    tmp,
    AnyDetected = as.integer(any(Detected)),
    OTU_Richness = sum(Detected),
    .groups = "drop"
  )

  tmp <- dplyr::mutate(tmp, Threshold = th)
  sample_level_list[[i]] <- tmp
}

sample_level_all <- dplyr::bind_rows(sample_level_list)

sample_level_all <- dplyr::mutate(
  sample_level_all,
  Nest_ID = factor(Nest_ID, levels = keep_nests),
  Month = factor(Month, levels = keep_months, ordered = TRUE),
  Guild = factor(Guild, levels = c("Truffle", "Epigeous_ECM"))
)

readr::write_csv(
  sample_level_all,
  file.path(out_dir, "mckenzie_h2_h4_sample_level_all_thresholds.csv")
)

# --------------------------------------------------
# Month-level summary across thresholds
# --------------------------------------------------
month_summary_all <- dplyr::group_by(sample_level_all, Month, Guild, Threshold)

month_summary_all <- dplyr::summarise(
  month_summary_all,
  N_Samples = dplyr::n(),
  Detection_Frequency = mean(AnyDetected),
  Mean_Sample_Richness = mean(OTU_Richness),
  Median_Sample_Richness = stats::median(OTU_Richness),
  Samples_With_Detection = sum(AnyDetected),
  .groups = "drop"
)

month_summary_all <- dplyr::mutate(
  month_summary_all,
  Month = factor(Month, levels = keep_months, ordered = TRUE),
  Guild = factor(Guild, levels = c("Truffle", "Epigeous_ECM"))
)

readr::write_csv(
  month_summary_all,
  file.path(out_dir, "mckenzie_h2_h4_month_level_summary_all_thresholds.csv")
)

# --------------------------------------------------
# Dedicated 1.0% plotting tables
# --------------------------------------------------
sample_level_plot <- dplyr::filter(sample_level_all, Threshold == plot_threshold)
month_summary_plot <- dplyr::filter(month_summary_all, Threshold == plot_threshold)

readr::write_csv(
  sample_level_plot,
  file.path(out_dir, "mckenzie_h2_sample_level_detection_1pct.csv")
)

readr::write_csv(
  month_summary_plot,
  file.path(out_dir, "mckenzie_h2_month_level_summary_1pct.csv")
)

# --------------------------------------------------
# Run H2 models separately at each threshold
# --------------------------------------------------
robustness_rows <- list()
diagnostics_rows <- list()

for (i in seq_along(thresholds)) {

  th <- thresholds[i]
  th_lab <- threshold_label(th)

  sample_th <- dplyr::filter(sample_level_all, Threshold == th)

  # ================================================
  # Truffle
  # ================================================
