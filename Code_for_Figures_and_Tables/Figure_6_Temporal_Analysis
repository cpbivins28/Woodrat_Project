# --------------------------------------------------------------------------
# Helper function: safely collect model warnings
# --------------------------------------------------------------------------

# Fit a model while capturing warnings so they can be saved and reported later.
fit_with_warnings <- function(expr) {
  warning_messages <- character(0)

  fit <- withCallingHandlers(
    tryCatch(
      expr,
      error = function(e) e
    ),
    warning = function(w) {
      warning_messages <<- c(warning_messages, conditionMessage(w))
      invokeRestart("muffleWarning")
    }
  )

  list(
    fit = fit,
    warnings = unique(warning_messages)
  )
}

# --------------------------------------------------------------------------
# Helper function: detect problematic mixed-model fit
# --------------------------------------------------------------------------

# Flag mixed models that are singular, failed, or otherwise unreliable.
mixed_model_problem <- function(model, warnings_vec = character(0)) {

  # Treat outright model errors as problematic.
  if (inherits(model, "error")) {
    return(TRUE)
  }

  # If the returned object is not a merMod object, it is not a valid mixed model.
  if (!inherits(model, "merMod")) {
    return(TRUE)
  }

  # Check singularity.
  singular_flag <- FALSE
  singular_flag <- tryCatch(
    lme4::isSingular(model, tol = 1e-4),
    error = function(e) FALSE
  )

  # Extract convergence messages if present.
  conv_messages <- character(0)
  conv_messages <- tryCatch(
    unlist(model@optinfo$conv$lme4$messages),
    error = function(e) character(0)
  )

  # Define warning patterns that indicate poor model fit.
  bad_warning_patterns <- c(
    "failed to converge",
    "degenerate",
    "singular",
    "non-positive-definite",
    "unable to evaluate scaled gradient",
    "Model failed to converge",
    "boundary \\(singular\\) fit"
  )

  # Check whether any warnings match the bad-fit patterns.
  has_bad_warning <- FALSE
  if (length(warnings_vec) > 0 || length(conv_messages) > 0) {
    all_msgs <- c(warnings_vec, conv_messages)
    has_bad_warning <- any(
      grepl(
        paste(bad_warning_patterns, collapse = "|"),
        all_msgs,
        ignore.case = TRUE
      )
    )
  }

  # Return TRUE if the model has any major fit problem.
  return(isTRUE(singular_flag) || has_bad_warning)
}

# --------------------------------------------------------------------------
# Helper function: compute overdispersion ratio
# --------------------------------------------------------------------------

# Compute a Pearson residual overdispersion ratio for GLMs or mixed models.
overdispersion_ratio <- function(model) {

  # Handle standard GLMs.
  if (inherits(model, "glm")) {
    rp <- residuals(model, type = "pearson")
    rdf <- df.residual(model)

    if (rdf <= 0) return(NA_real_)
    return(sum(rp^2, na.rm = TRUE) / rdf)
  }

  # Handle mixed models approximately.
  if (inherits(model, "merMod")) {
    rp <- residuals(model, type = "pearson")
    n_obs <- nobs(model)

    # Approximate residual df pragmatically.
    n_fixef <- tryCatch(length(lme4::fixef(model)), error = function(e) NA_integer_)
    rdf <- n_obs - n_fixef - 1

    if (is.na(rdf) || rdf <= 0) return(NA_real_)
    return(sum(rp^2, na.rm = TRUE) / rdf)
  }

  # Return NA if model class is unsupported.
  return(NA_real_)
}

# --------------------------------------------------------------------------
# Helper function: fit detection model with mixed first, fixed fallback
# --------------------------------------------------------------------------

# Fit the month effect on AnyDetected using the same logic as the original script.
fit_detection_model <- function(dat) {

  # Attempt the full mixed model first.
  full_mixed_fit <- fit_with_warnings(
    lme4::glmer(
      AnyDetected ~ Month + (1 | Nest_ID),
      family = stats::binomial,
      data = dat,
      control = lme4::glmerControl(
        optimizer = "bobyqa",
        optCtrl = list(maxfun = 2e5)
      )
    )
  )

  # Attempt the reduced mixed model without Month.
  red_mixed_fit <- fit_with_warnings(
    lme4::glmer(
      AnyDetected ~ (1 | Nest_ID),
      family = stats::binomial,
      data = dat,
      control = lme4::glmerControl(
        optimizer = "bobyqa",
        optCtrl = list(maxfun = 2e5)
      )
    )
  )

  # Evaluate whether mixed-model fitting was acceptable.
  mixed_ok <- TRUE
  mixed_ok <- mixed_ok && !inherits(full_mixed_fit$fit, "error")
  mixed_ok <- mixed_ok && !inherits(red_mixed_fit$fit, "error")
  mixed_ok <- mixed_ok && !mixed_model_problem(full_mixed_fit$fit, full_mixed_fit$warnings)
  mixed_ok <- mixed_ok && !mixed_model_problem(red_mixed_fit$fit, red_mixed_fit$warnings)

  # If acceptable, return the mixed model.
  if (isTRUE(mixed_ok)) {
    return(list(
      full_model = full_mixed_fit$fit,
      reduced_model = red_mixed_fit$fit,
      model_type = "mixed_random_intercept",
      family = "binomial",
      warnings = unique(c(full_mixed_fit$warnings, red_mixed_fit$warnings))
    ))
  }

  # Otherwise, fall back to fixed-effect Nest_ID.
  full_fixed <- stats::glm(
    AnyDetected ~ Month + Nest_ID,
    family = stats::binomial,
    data = dat
  )

  reduced_fixed <- stats::glm(
    AnyDetected ~ Nest_ID,
    family = stats::binomial,
    data = dat
  )

  return(list(
    full_model = full_fixed,
    reduced_model = reduced_fixed,
    model_type = "fixed_effect_nest",
    family = "binomial",
    warnings = unique(c(full_mixed_fit$warnings, red_mixed_fit$warnings))
  ))
}

# --------------------------------------------------------------------------
# Helper function: fit richness model with mixed first, fixed fallback
# --------------------------------------------------------------------------

# Fit the month effect on OTU_Richness using the same logic as the original script.
fit_richness_model <- function(dat) {

  # Try Poisson mixed model first.
  full_pois_mixed_fit <- fit_with_warnings(
    lme4::glmer(
      OTU_Richness ~ Month + (1 | Nest_ID),
      family = stats::poisson,
      data = dat,
      control = lme4::glmerControl(
        optimizer = "bobyqa",
        optCtrl = list(maxfun = 2e5)
      )
    )
  )

  # Fit reduced Poisson mixed model.
  red_pois_mixed_fit <- fit_with_warnings(
    lme4::glmer(
      OTU_Richness ~ (1 | Nest_ID),
      family = stats::poisson,
      data = dat,
      control = lme4::glmerControl(
        optimizer = "bobyqa",
        optCtrl = list(maxfun = 2e5)
      )
    )
  )

  # Evaluate whether Poisson mixed models are acceptable.
  pois_mixed_ok <- TRUE
  pois_mixed_ok <- pois_mixed_ok && !inherits(full_pois_mixed_fit$fit, "error")
  pois_mixed_ok <- pois_mixed_ok && !inherits(red_pois_mixed_fit$fit, "error")
  pois_mixed_ok <- pois_mixed_ok && !mixed_model_problem(full_pois_mixed_fit$fit, full_pois_mixed_fit$warnings)
  pois_mixed_ok <- pois_mixed_ok && !mixed_model_problem(red_pois_mixed_fit$fit, red_pois_mixed_fit$warnings)

  # If the Poisson mixed model is acceptable, examine overdispersion.
  if (isTRUE(pois_mixed_ok)) {

    full_model <- full_pois_mixed_fit$fit
    reduced_model <- red_pois_mixed_fit$fit
    disp <- overdispersion_ratio(full_model)

    # If overdispersion is modest, keep the Poisson mixed model.
    if (is.na(disp) || disp <= 1.5) {
      return(list(
        full_model = full_model,
        reduced_model = reduced_model,
        model_type = "mixed_random_intercept",
        family = "poisson",
        poisson_overdispersion_ratio = disp,
        warnings = unique(c(full_pois_mixed_fit$warnings, red_pois_mixed_fit$warnings))
      ))
    }

    # If overdispersed, try negative binomial mixed models.
    full_nb_mixed_fit <- fit_with_warnings(
      lme4::glmer.nb(
        OTU_Richness ~ Month + (1 | Nest_ID),
        data = dat,
        control = lme4::glmerControl(
          optimizer = "bobyqa",
          optCtrl = list(maxfun = 2e5)
        )
      )
    )

    red_nb_mixed_fit <- fit_with_warnings(
      lme4::glmer.nb(
        OTU_Richness ~ (1 | Nest_ID),
        data = dat,
        control = lme4::glmerControl(
          optimizer = "bobyqa",
          optCtrl = list(maxfun = 2e5)
        )
      )
    )

    # Evaluate whether negative binomial mixed models are acceptable.
    nb_mixed_ok <- TRUE
    nb_mixed_ok <- nb_mixed_ok && !inherits(full_nb_mixed_fit$fit, "error")
    nb_mixed_ok <- nb_mixed_ok && !inherits(red_nb_mixed_fit$fit, "error")
    nb_mixed_ok <- nb_mixed_ok && !mixed_model_problem(full_nb_mixed_fit$fit, full_nb_mixed_fit$warnings)
    nb_mixed_ok <- nb_mixed_ok && !mixed_model_problem(red_nb_mixed_fit$fit, red_nb_mixed_fit$warnings)

    # If acceptable, keep the negative binomial mixed model.
    if (isTRUE(nb_mixed_ok)) {
      return(list(
        full_model = full_nb_mixed_fit$fit,
        reduced_model = red_nb_mixed_fit$fit,
        model_type = "mixed_random_intercept",
        family = "negative_binomial",
        poisson_overdispersion_ratio = disp,
        warnings = unique(c(
          full_pois_mixed_fit$warnings,
          red_pois_mixed_fit$warnings,
          full_nb_mixed_fit$warnings,
          red_nb_mixed_fit$warnings
        ))
      ))
    }
  }

  # If mixed models fail, fit fixed-effect Nest_ID models.
  full_pois_fixed <- stats::glm(
    OTU_Richness ~ Month + Nest_ID,
    family = stats::poisson,
    data = dat
  )

  disp_fixed <- overdispersion_ratio(full_pois_fixed)

  # If fixed-effect Poisson is overdispersed, use fixed-effect NB.
  if (!is.na(disp_fixed) && disp_fixed > 1.5) {

    full_nb_fixed <- MASS::glm.nb(
      OTU_Richness ~ Month + Nest_ID,
      data = dat
    )

    red_nb_fixed <- MASS::glm.nb(
      OTU_Richness ~ Nest_ID,
      data = dat
    )

    return(list(
      full_model = full_nb_fixed,
      reduced_model = red_nb_fixed,
      model_type = "fixed_effect_nest",
      family = "negative_binomial",
      poisson_overdispersion_ratio = disp_fixed,
      warnings = character(0)
    ))
  }

  # Otherwise keep the fixed-effect Poisson model.
  red_pois_fixed <- stats::glm(
    OTU_Richness ~ Nest_ID,
    family = stats::poisson,
    data = dat
  )

  return(list(
    full_model = full_pois_fixed,
    reduced_model = red_pois_fixed,
    model_type = "fixed_effect_nest",
    family = "poisson",
    poisson_overdispersion_ratio = disp_fixed,
    warnings = character(0)
  ))
}

# --------------------------------------------------------------------------
# Helper function: inverse-link behavior by response family
# --------------------------------------------------------------------------

# Return the inverse-link function appropriate for each model family.
inverse_link <- function(eta, family_name) {
  if (family_name == "binomial") {
    return(stats::plogis(eta))
  }
  if (family_name %in% c("poisson", "negative_binomial")) {
    return(exp(eta))
  }
  stop(paste("Unsupported family:", family_name))
}

# --------------------------------------------------------------------------
# Helper function: build balanced prediction grid
# --------------------------------------------------------------------------

# Build a newdata grid for month predictions.
build_prediction_grid <- function(model_type, months, nests) {

  # For mixed models, predictions depend only on the fixed Month effect and
  # are made at the population level with random intercept = 0.
  if (model_type == "mixed_random_intercept") {
    newdata <- data.frame(
      Month = factor(months, levels = months, ordered = TRUE)
    )
    return(newdata)
  }

  # For fixed-effect Nest_ID models, create all month × nest combinations so
  # predictions can later be averaged equally across nests.
  if (model_type == "fixed_effect_nest") {
    newdata <- expand.grid(
      Month = months,
      Nest_ID = nests,
      stringsAsFactors = FALSE
    )

    newdata$Month <- factor(newdata$Month, levels = months, ordered = TRUE)
    newdata$Nest_ID <- factor(newdata$Nest_ID, levels = nests)

    return(newdata)
  }

  stop(paste("Unsupported model_type:", model_type))
}

# --------------------------------------------------------------------------
# Helper function: extract month-specific predictions and CIs
# --------------------------------------------------------------------------

# Generate month-specific predictions and Wald CIs on the response scale.
extract_month_predictions <- function(model, model_type, family_name,
                                      threshold_value, guild_label, response_label,
                                      months, nests) {

  # Build the balanced prediction grid.
  newdata <- build_prediction_grid(
    model_type = model_type,
    months = months,
    nests = nests
  )

  # For mixed models, obtain fixed-effects design matrix from the fixed-only formula.
  if (inherits(model, "merMod")) {

    # Build a one-sided fixed-effects formula from the model's fixed effects.
    fixed_formula <- lme4::nobars(formula(model))

    # Delete the response so model.matrix can be built on newdata.
    fixed_terms <- stats::delete.response(stats::terms(fixed_formula))

    # Construct the fixed-effects design matrix.
    X <- stats::model.matrix(fixed_terms, newdata)

    # Extract fixed-effect coefficients.
    beta <- lme4::fixef(model)

    # Extract fixed-effect variance-covariance matrix.
    V <- as.matrix(vcov(model))

    # Compute predictions on the link scale.
    eta <- as.vector(X %*% beta)

    # Compute link-scale standard errors.
    se_eta <- sqrt(diag(X %*% V %*% t(X)))
  } else {

    # For standard GLMs, use the same model-matrix logic.
    terms_obj <- stats::delete.response(stats::terms(model))
    X <- stats::model.matrix(terms_obj, newdata)
    beta <- stats::coef(model)
    V <- as.matrix(vcov(model))

    eta <- as.vector(X %*% beta)
    se_eta <- sqrt(diag(X %*% V %*% t(X)))
  }

  # Compute link-scale confidence limits.
  eta_lower <- eta - 1.96 * se_eta
  eta_upper <- eta + 1.96 * se_eta

  # Convert predictions to the response scale.
  pred <- inverse_link(eta, family_name)
  pred_lower <- inverse_link(eta_lower, family_name)
  pred_upper <- inverse_link(eta_upper, family_name)

  # Bind predictions back onto the prediction grid.
  pred_df <- newdata
  pred_df$eta <- eta
  pred_df$se_eta <- se_eta
  pred_df$Predicted <- pred
  pred_df$CI_Lower <- pred_lower
  pred_df$CI_Upper <- pred_upper

  # If the model is mixed, each row is already one month-level prediction.
  if (model_type == "mixed_random_intercept") {
    out <- pred_df %>%
      dplyr::transmute(
        Threshold = threshold_value,
        Guild = guild_label,
        Response = response_label,
        Month = Month,
        Model_Type = model_type,
        Model_Family = family_name,
        Predicted = Predicted,
        CI_Lower = CI_Lower,
        CI_Upper = CI_Upper
      )
    return(out)
  }

  # If the model is fixed-effect Nest_ID, average equally across nests within month.
  # This yields month predictions adjusted for nest while avoiding unequal sample-size weighting.
  if (model_type == "fixed_effect_nest") {
    out <- pred_df %>%
      dplyr::group_by(Month) %>%
      dplyr::summarise(
        Predicted = mean(Predicted, na.rm = TRUE),
        CI_Lower = mean(CI_Lower, na.rm = TRUE),
        CI_Upper = mean(CI_Upper, na.rm = TRUE),
        .groups = "drop"
      ) %>%
      dplyr::mutate(
        Threshold = threshold_value,
        Guild = guild_label,
        Response = response_label,
        Model_Type = model_type,
        Model_Family = family_name
      ) %>%
      dplyr::select(
        Threshold, Guild, Response, Month,
        Model_Type, Model_Family,
        Predicted, CI_Lower, CI_Upper
      )
    return(out)
  }

  stop("Unhandled model type in prediction extraction.")
}

