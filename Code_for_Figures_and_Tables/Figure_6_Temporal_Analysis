# Load reshaping tools.
library(tidyr)

# Load CSV import/export functions.
library(readr)

# Load support for mixed-model coefficient tidying if needed later.
library(broom)
library(broom.mixed)

# Load tibble helpers.
library(tibble)

# Load negative binomial GLMs.
library(MASS)

# Load GLMM tools.
library(lme4)

# --------------------------------------------------------------------------
# Paths
# --------------------------------------------------------------------------

# Define input OTU table path.
otu_fp   <- "/Users/cbivins/Desktop/Woodrat_Project_NEATEST/working_data/otu_table_collapsed_relative.csv"

# Define input guild table path.
