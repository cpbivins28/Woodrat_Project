# --------------------------------------------------
# Helper function: threshold label for filenames
# --------------------------------------------------
threshold_label <- function(x) {
  if (x == 0) return("0pct")
  out <- gsub("\\.", "p", as.character(x))
  paste0(out, "pct")
}

# --------------------------------------------------
# Helper function: safely extract p-value column from drop1 output
# --------------------------------------------------
extract_drop1_table <- function(drop1_obj) {
  tab <- as.data.frame(drop1_obj)
  tab <- tibble::rownames_to_column(tab, "Term")
  tab <- dplyr::filter(tab, Term != "<none>")

  p_col <- grep("^Pr\\(", colnames(tab), value = TRUE)
  if (length(p_col) != 1) {
    stop("Could not uniquely identify p-value column in drop1 table.")
  }

  if ("LRT" %in% colnames(tab)) {
    stat_col <- "LRT"
  } else if ("Deviance" %in% colnames(tab)) {
    stat_col <- "Deviance"
  } else {
    stop("Could not identify test statistic column in drop1 table.")
  }

  out <- dplyr::transmute(
    tab,
    Term = Term,
    Df = Df,
    Chisq = .data[[stat_col]],
    p_value = .data[[p_col]]
  )
  return(out)
}

# --------------------------------------------------
# Helper function: compute overdispersion ratio for Poisson GLM
# --------------------------------------------------
overdispersion_ratio <- function(model) {
  rp <- residuals(model, type = "pearson")
  rdf <- df.residual(model)
  if (rdf <= 0) return(NA_real_)
  sum(rp^2) / rdf
}

# --------------------------------------------------
# Helper function: fit richness model with NB fallback
# --------------------------------------------------
fit_richness_model <- function(dat) {
  pois_model <- stats::glm(
    OTU_Richness ~ Nest_ID,
    family = stats::poisson,
    data = dat
  )

  disp <- overdispersion_ratio(pois_model)

  if (!is.na(disp) && disp > 1.5) {
    final_model <- MASS::glm.nb(
      OTU_Richness ~ Nest_ID,
      data = dat
    )
    final_family <- "negative_binomial"
  } else {
    final_model <- pois_model
    final_family <- "poisson"
  }

  out <- list(
    model = final_model,
    family = final_family,
    poisson_overdispersion_ratio = disp
  )

  return(out)
}

