otu_long <- dplyr::left_join(otu_long, meta_mck, by = "Sample_ID")

otu_long <- dplyr::mutate(
  otu_long,
  Guild = dplyr::case_when(
    OTU_ID %in% truffle_ids ~ "Truffle",
    OTU_ID %in% epigeous_ids ~ "Epigeous_ECM",
    TRUE ~ NA_character_
  )
)

otu_long <- dplyr::filter(otu_long, !is.na(Guild))

