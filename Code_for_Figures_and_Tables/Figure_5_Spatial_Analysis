"""
Purpose:
    Create two separate SVG panels for the McKenzie H2/H4 spatial figure.

Inputs:
    1) mckenzie_h1_nest_level_summary_1pct.csv
       - used for Panel A: detection frequency by nest and guild
    2) mckenzie_h1_nest_cumulative_otu_richness_1pct.csv
       - used for Panel B: cumulative OTU richness by nest and guild

Logic:
    - Read the two input CSV files
    - Standardize nest order and guild order
    - Build paired bar plots for:
        Panel A = Detection frequency
        Panel B = Cumulative OTU richness
    - Save each panel separately as an SVG

Outputs:
    1) panel_A_detection_frequency_1pct.svg
    2) panel_B_cumulative_richness_1pct.svg
"""

# -----------------------------
# Imports
# -----------------------------
import os
from pathlib import Path

# Import pandas for table handling.
import pandas as pd

# Import matplotlib for plotting.
import matplotlib.pyplot as plt

# -----------------------------
# File paths
# -----------------------------
# Define the base directory containing the R output files.
base_dir = Path("/Users/cbivins/Desktop/Woodrat_Project_NEATEST/mckenzie_h1_h4_spatial")

# Define the output directory for plots.
plot_dir = Path("/Users/cbivins/Desktop/Woodrat_Project_NEATEST/mckenzie_h1_h4_spatial/plots")

# Create the plot output directory if it does not already exist.
plot_dir.mkdir(parents=True, exist_ok=True)

# Define input file paths.
detection_fp = base_dir / "mckenzie_h1_nest_level_summary_1pct.csv"
richness_fp = base_dir / "mckenzie_h1_nest_cumulative_otu_richness_1pct.csv"

# -----------------------------
# User-defined plotting settings
# -----------------------------
# Fix the nest order exactly as requested.
nest_order = ["M1", "M3", "M6", "M8", "M9", "M10"]

# Fix the guild order so plotting is consistent.
guild_order = ["Truffle", "Epigeous_ECM"]

# Use a color-blind friendly palette.
# Blue-green for truffles, orange for epigeous ECM.
guild_colors = {
    "Truffle": "#1B9E77",
    "Epigeous_ECM": "#D95F02"
}

# Define the bar width for paired bars.
bar_width = 0.38

# -----------------------------
# Load input data
# -----------------------------
# Read the detection-frequency summary table.
detection_df = pd.read_csv(detection_fp)

# Read the cumulative richness summary table.
richness_df = pd.read_csv(richness_fp)

# -----------------------------
# Basic input checks
# -----------------------------
# Verify required columns are present in the detection table.
required_detection_cols = {"Nest_ID", "Guild", "Detection_Frequency"}
missing_detection = required_detection_cols - set(detection_df.columns)
if missing_detection:
    raise ValueError(
        f"Detection summary file is missing required columns: {sorted(missing_detection)}"
    )

# Verify required columns are present in the cumulative richness table.
required_richness_cols = {"Nest_ID", "Guild", "Cumulative_Unique_OTUs"}
missing_richness = required_richness_cols - set(richness_df.columns)
if missing_richness:
    raise ValueError(
        f"Cumulative richness file is missing required columns: {sorted(missing_richness)}"
    )

# -----------------------------
# Standardize categorical order
# -----------------------------
# Convert Nest_ID to an ordered categorical in the detection table.
detection_df["Nest_ID"] = pd.Categorical(
    detection_df["Nest_ID"],
    categories=nest_order,
    ordered=True
)

# Convert Guild to an ordered categorical in the detection table.
detection_df["Guild"] = pd.Categorical(
    detection_df["Guild"],
    categories=guild_order,
    ordered=True
)

# Convert Nest_ID to an ordered categorical in the richness table.
richness_df["Nest_ID"] = pd.Categorical(
    richness_df["Nest_ID"],
    categories=nest_order,
    ordered=True
)

# Convert Guild to an ordered categorical in the richness table.
richness_df["Guild"] = pd.Categorical(
    richness_df["Guild"],
    categories=guild_order,
    ordered=True
)

# Sort both tables so plotting is deterministic.
detection_df = detection_df.sort_values(["Nest_ID", "Guild"]).reset_index(drop=True)
richness_df = richness_df.sort_values(["Nest_ID", "Guild"]).reset_index(drop=True)

# -----------------------------
# Reshape for plotting
# -----------------------------
# Pivot the detection table so rows are nests and columns are guilds.
detection_wide = detection_df.pivot(
    index="Nest_ID",
    columns="Guild",
    values="Detection_Frequency"
)

# Reindex to enforce exact nest and guild order.
detection_wide = detection_wide.reindex(index=nest_order, columns=guild_order)

# Pivot the richness table so rows are nests and columns are guilds.
richness_wide = richness_df.pivot(
    index="Nest_ID",
    columns="Guild",
    values="Cumulative_Unique_OTUs"
)

# Reindex to enforce exact nest and guild order.
richness_wide = richness_wide.reindex(index=nest_order, columns=guild_order)

# -----------------------------
# Helper function for consistent styling
# -----------------------------
def style_axes(ax):
    """Apply consistent, clean figure styling."""
    # Remove gridlines as requested.
    ax.grid(False)

    # Hide the top and right spines for a cleaner look.
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)

    # Make tick labels readable.
    ax.tick_params(axis="x", labelsize=11)
    ax.tick_params(axis="y", labelsize=11)

# -----------------------------
# Panel A: Detection frequency
# -----------------------------
# Create a new figure for Panel A only.
fig, ax = plt.subplots(figsize=(7, 5))

# Define x positions for nests.
x_positions = range(len(nest_order))

# Compute offset positions for paired bars.
x_truffle = [x - bar_width / 2 for x in x_positions]
x_epigeous = [x + bar_width / 2 for x in x_positions]

# Plot truffle bars.
ax.bar(
    x_truffle,
    detection_wide["Truffle"].values,
    width=bar_width,
    label="Truffle",
    color=guild_colors["Truffle"]
)

# Plot epigeous ECM bars.
ax.bar(
    x_epigeous,
    detection_wide["Epigeous_ECM"].values,
    width=bar_width,
    label="Epigeous ECM",
    color=guild_colors["Epigeous_ECM"]
)

# Set x-axis tick positions and labels.
ax.set_xticks(list(x_positions))
ax.set_xticklabels(nest_order)

# Label the axes clearly.
ax.set_xlabel("Nest ID", fontsize=12)
ax.set_ylabel("Detection frequency", fontsize=12)

# Set the y-axis to proportion scale.
ax.set_ylim(0, 1)

# Add a simple title for the exported panel.
ax.set_title("Panel A. Detection frequency at 1.0% threshold", fontsize=13)

# Add legend.
ax.legend(frameon=False, fontsize=11)

# Apply consistent styling.
style_axes(ax)

# Tighten layout so labels are not clipped.
fig.tight_layout()

# Save Panel A as SVG.
panel_a_fp = plot_dir / "panel_A_detection_frequency_1pct.svg"
fig.savefig(panel_a_fp, format="svg", bbox_inches="tight")

# Close the figure to avoid carryover.
plt.close(fig)

# -----------------------------
# Panel B: Cumulative richness
# -----------------------------
# Create a new figure for Panel B only.
fig, ax = plt.subplots(figsize=(7, 5))

# Plot truffle bars for cumulative richness.
ax.bar(
    x_truffle,
    richness_wide["Truffle"].values,
    width=bar_width,
    label="Truffle",
    color=guild_colors["Truffle"]
)

# Plot epigeous ECM bars for cumulative richness.
ax.bar(
    x_epigeous,
    richness_wide["Epigeous_ECM"].values,
    width=bar_width,
    label="Epigeous ECM",
    color=guild_colors["Epigeous_ECM"]
)

# Set x-axis tick positions and labels.
ax.set_xticks(list(x_positions))
ax.set_xticklabels(nest_order)

# Label the axes clearly.
ax.set_xlabel("Nest ID", fontsize=12)
ax.set_ylabel("Cumulative OTU richness per nest", fontsize=12)

# Start y-axis at zero.
ax.set_ylim(bottom=0)

# Add a simple title for the exported panel.
ax.set_title("Panel B. Cumulative OTU richness at 1.0% threshold", fontsize=13)

# Add legend.
ax.legend(frameon=False, fontsize=11)

# Apply consistent styling.
style_axes(ax)

# Tighten layout so labels are not clipped.
fig.tight_layout()

# Save Panel B as SVG.
panel_b_fp = plot_dir / "panel_B_cumulative_richness_1pct.svg"
fig.savefig(panel_b_fp, format="svg", bbox_inches="tight")

# Close the figure.
plt.close(fig)

# -----------------------------
# Final console message
# -----------------------------
print("Done.")
print(f"Saved: {panel_a_fp}")
print(f"Saved: {panel_b_fp}")
