  th <- thresholds[i]
  th_lab <- threshold_label(th)

  sample_th <- dplyr::filter(sample_level_all, Threshold == th)

  # ================================================
  # Truffle
  # ================================================
  truf_dat <- dplyr::filter(sample_th, Guild == "Truffle")

  # Detection model
  truf_det_glm <- stats::glm(
    AnyDetected ~ Nest_ID,
    family = stats::binomial,
    data = truf_dat
  )

  truf_det_anova <- stats::drop1(truf_det_glm, test = "Chisq")
  truf_det_anova <- extract_drop1_table(truf_det_anova)
  truf_det_coef  <- broom::tidy(truf_det_glm)

  truf_det_anova <- dplyr::mutate(
    truf_det_anova,
    Threshold = th,
    Guild = "Truffle",
    Model = "Detection"
  )

  truf_det_coef <- dplyr::mutate(
    truf_det_coef,
    Threshold = th,
    Guild = "Truffle",
    Model = "Detection"
  )

  readr::write_csv(
    truf_det_anova,
    file.path(out_dir, paste0("mckenzie_h1_detection_anova_truffle_", th_lab, ".csv"))
  )

  readr::write_csv(
    truf_det_coef,
    file.path(out_dir, paste0("mckenzie_h1_detection_coefficients_truffle_", th_lab, ".csv"))
  )

  # Richness model
  truf_rich_fit <- fit_richness_model(truf_dat)
  truf_rich_model <- truf_rich_fit$model
  truf_rich_family <- truf_rich_fit$family
  truf_disp <- truf_rich_fit$poisson_overdispersion_ratio

  truf_rich_anova <- stats::drop1(truf_rich_model, test = "Chisq")
  truf_rich_anova <- extract_drop1_table(truf_rich_anova)
  truf_rich_coef  <- broom::tidy(truf_rich_model)

  truf_rich_anova <- dplyr::mutate(
    truf_rich_anova,
    Threshold = th,
    Guild = "Truffle",
    Model = "Richness",
    Richness_Model = truf_rich_family,
    Poisson_Overdispersion_Ratio = truf_disp
  )

  truf_rich_coef <- dplyr::mutate(
    truf_rich_coef,
    Threshold = th,
    Guild = "Truffle",
    Model = "Richness",
    Richness_Model = truf_rich_family,
    Poisson_Overdispersion_Ratio = truf_disp
  )

  readr::write_csv(
    truf_rich_anova,
    file.path(out_dir, paste0("mckenzie_h1_richness_anova_truffle_", th_lab, ".csv"))
  )

  readr::write_csv(
    truf_rich_coef,
    file.path(out_dir, paste0("mckenzie_h1_richness_coefficients_truffle_", th_lab, ".csv"))
  )

  # Robustness row: truffle
  truf_det_nest <- dplyr::filter(truf_det_anova, Term == "Nest_ID")
  truf_rich_nest <- dplyr::filter(truf_rich_anova, Term == "Nest_ID")

  robustness_rows[[length(robustness_rows) + 1]] <- data.frame(
    Threshold = th,
    Guild = "Truffle",
    Detection_Nest_Chisq = truf_det_nest$Chisq,
    Detection_Nest_Df = truf_det_nest$Df,
    Detection_Nest_p = truf_det_nest$p_value,
    Richness_Nest_Chisq = truf_rich_nest$Chisq,
    Richness_Nest_Df = truf_rich_nest$Df,
    Richness_Nest_p = truf_rich_nest$p_value,
    Richness_Model = truf_rich_family,
    Poisson_Overdispersion_Ratio = truf_disp
  )

  diagnostics_rows[[length(diagnostics_rows) + 1]] <- data.frame(
    Threshold = th,
    Guild = "Truffle",
    Richness_Model = truf_rich_family,
    Poisson_Overdispersion_Ratio = truf_disp
  )

  # ================================================
  # Epigeous ECM
  # ================================================
  epi_dat <- dplyr::filter(sample_th, Guild == "Epigeous_ECM")

  # Detection model
  epi_det_glm <- stats::glm(
    AnyDetected ~ Nest_ID,
    family = stats::binomial,
    data = epi_dat
  )

  epi_det_anova <- stats::drop1(epi_det_glm, test = "Chisq")
  epi_det_anova <- extract_drop1_table(epi_det_anova)
  epi_det_coef  <- broom::tidy(epi_det_glm)

  epi_det_anova <- dplyr::mutate(
    epi_det_anova,
    Threshold = th,
    Guild = "Epigeous_ECM",
    Model = "Detection"
  )

  epi_det_coef <- dplyr::mutate(
    epi_det_coef,
    Threshold = th,
    Guild = "Epigeous_ECM",
    Model = "Detection"
  )

  readr::write_csv(
    epi_det_anova,
    file.path(out_dir, paste0("mckenzie_h1_detection_anova_epigeous_", th_lab, ".csv"))
  )

  readr::write_csv(
    epi_det_coef,
    file.path(out_dir, paste0("mckenzie_h1_detection_coefficients_epigeous_", th_lab, ".csv"))
  )

  # Richness model
  epi_rich_fit <- fit_richness_model(epi_dat)
  epi_rich_model <- epi_rich_fit$model
  epi_rich_family <- epi_rich_fit$family
  epi_disp <- epi_rich_fit$poisson_overdispersion_ratio

  epi_rich_anova <- stats::drop1(epi_rich_model, test = "Chisq")
  epi_rich_anova <- extract_drop1_table(epi_rich_anova)
  epi_rich_coef  <- broom::tidy(epi_rich_model)

  epi_rich_anova <- dplyr::mutate(
    epi_rich_anova,
    Threshold = th,
    Guild = "Epigeous_ECM",
    Model = "Richness",
    Richness_Model = epi_rich_family,
    Poisson_Overdispersion_Ratio = epi_disp
  )

  epi_rich_coef <- dplyr::mutate(
    epi_rich_coef,
    Threshold = th,
    Guild = "Epigeous_ECM",
    Model = "Richness",
    Richness_Model = epi_rich_family,
    Poisson_Overdispersion_Ratio = epi_disp
  )

  readr::write_csv(
    epi_rich_anova,
    file.path(out_dir, paste0("mckenzie_h1_richness_anova_epigeous_", th_lab, ".csv"))
  )

  readr::write_csv(
    epi_rich_coef,
    file.path(out_dir, paste0("mckenzie_h1_richness_coefficients_epigeous_", th_lab, ".csv"))
  )

  # Robustness row: epigeous
  epi_det_nest <- dplyr::filter(epi_det_anova, Term == "Nest_ID")
  epi_rich_nest <- dplyr::filter(epi_rich_anova, Term == "Nest_ID")

  robustness_rows[[length(robustness_rows) + 1]] <- data.frame(
    Threshold = th,
    Guild = "Epigeous_ECM",
    Detection_Nest_Chisq = epi_det_nest$Chisq,
    Detection_Nest_Df = epi_det_nest$Df,
    Detection_Nest_p = epi_det_nest$p_value,
    Richness_Nest_Chisq = epi_rich_nest$Chisq,
    Richness_Nest_Df = epi_rich_nest$Df,
    Richness_Nest_p = epi_rich_nest$p_value,
    Richness_Model = epi_rich_family,
    Poisson_Overdispersion_Ratio = epi_disp
  )

  diagnostics_rows[[length(diagnostics_rows) + 1]] <- data.frame(
    Threshold = th,
    Guild = "Epigeous_ECM",
    Richness_Model = epi_rich_family,
    Poisson_Overdispersion_Ratio = epi_disp
