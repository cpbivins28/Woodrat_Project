#!/bin/bash
# ============================================================
# run_custom_blast.sh
# Build BLAST database and search OTU representative sequences
# against FUNDIS + Local reference DB (with query coverage output)
# ============================================================

set -euo pipefail

# ------------------------------------------------------------
# CONFIGURATION
# ------------------------------------------------------------
DB_DIR="blast_db"
INPUT_FASTA="input/my_Sequences_plus_FUNDIS_FINAL.fa"
QUERY_FASTA="input/taxonomyITS.otus.taxonomy.fa"
OUT_TSV="output/woodrat_OTUs_vs_customITS_BLAST.tsv"

# ------------------------------------------------------------
# MAKE DATABASE
# ------------------------------------------------------------
echo "============================================================"
echo "Building BLAST database from $INPUT_FASTA..."
echo "Output DB directory: $DB_DIR"
echo "============================================================"

mkdir -p "$DB_DIR"
makeblastdb -in "$INPUT_FASTA" -dbtype nucl -out "$DB_DIR/custom_ITS_db"

# ------------------------------------------------------------
# RUN BLAST (MEGABLAST MODE)
# ------------------------------------------------------------
echo ""
echo "Running BLAST search..."
blastn \
  -query "$QUERY_FASTA" \
  -db "$DB_DIR/custom_ITS_db" \
  -task megablast \
  -outfmt "6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send qcovs evalue bitscore" \
  -evalue 1e-20 \
  -max_target_seqs 1 \
  -num_threads 4 \
  -out "$OUT_TSV"

# ------------------------------------------------------------
# DONE
# ------------------------------------------------------------
echo ""
echo "✅ BLAST complete."
echo "Results saved to: $(realpath "$OUT_TSV")"
echo "============================================================"
echo "Columns in output:"
echo "qseqid | sseqid | pident | length | mismatch | gapopen | qstart | qend | sstart | send | qcovs | evalue | bitscore"
echo "============================================================"





