#!/usr/bin/env python3
import os
import re
import pandas as pd

# ============================================================
# Paths
# ============================================================
base = "/Users/cbivins/Desktop/Woodrat_Project_NEATEST/Figure_4/custom_blast"
blast_tsv = f"{base}/output/woodrat_OTUs_vs_customITS_BLAST.tsv"
out_csv = f"{base}/output/voucher_match_summary_all_thresholds.csv"

# ============================================================
# Load BLAST results
# ============================================================
cols = [
    "qseqid","sseqid","pident","length","mismatch","gapopen",
    "qstart","qend","sstart","send","qcovs","evalue","bitscore"
]

df = pd.read_csv(blast_tsv, sep="\t", header=None, names=cols)

# Only hits with 100% query coverage
df = df[df["qcovs"] == 100]

# ============================================================
# Helper: Identify FUNDIS vs Local
# ============================================================
uuid_pattern = re.compile(r"^[0-9a-f\-]{36}$")

def classify_source(sseqid):
    header = sseqid.split()[0]
    if uuid_pattern.fullmatch(header):
        return "FUNDIS"
    if any(c.isupper() for c in header):
        return "Local"
    # If something unexpected appears, classify as Unknown.
    return "Unknown"

df["Source"] = df["sseqid"].apply(classify_source)

# ============================================================
# Identity bins (mutually exclusive)
# ============================================================
def identity_bin(pid):
    if 97.0 <= pid < 98.0:
        return "97–98"
    elif 98.0 <= pid < 99.0:
        return "98–99"
    elif 99.0 <= pid < 100.0:
        return "99–100"
    elif pid == 100.0:
        return "100"
    else:
        return None  # below 97%

df["Identity_Range"] = df["pident"].apply(identity_bin)

# Filter out <97% identity
df = df.dropna(subset=["Identity_Range"])

# ============================================================
# Summarize counts
# ============================================================
summary = (
    df.groupby(["Identity_Range", "Source"])
      .size()
      .unstack(fill_value=0)
      .reset_index()
)

# Ensure both columns exist
for col in ["FUNDIS", "Local"]:
    if col not in summary.columns:
        summary[col] = 0

# Order rows logically
desired_order = ["97–98", "98–99", "99–100", "100"]
summary["order"] = summary["Identity_Range"].apply(lambda x: desired_order.index(x))
summary = summary.sort_values("order").drop(columns="order")

# ============================================================
# Write output
# ============================================================
summary.to_csv(out_csv, index=False)
print("Wrote summary file:")
print(out_csv)



